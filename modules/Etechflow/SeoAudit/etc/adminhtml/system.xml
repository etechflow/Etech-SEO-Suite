<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Config:etc/system_file.xsd">
    <system>
        <tab id="etechflow" translate="label" sortOrder="400">
            <label>Etechflow</label>
        </tab>
        <section id="etechflow_seoaudit" translate="label" type="text" sortOrder="50" showInDefault="1" showInWebsite="0" showInStore="0">
            <label>SEO Audit</label>
            <tab>etechflow</tab>
            <resource>Etechflow_SeoAudit::config</resource>
            <group id="general" translate="label" type="text" sortOrder="10" showInDefault="1">
                <label>Thresholds</label>
                <field id="enabled" translate="label" type="select" sortOrder="10" showInDefault="1">
                    <label>Enable</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <comment>Master switch for the audit feature.</comment>
                </field>
                <field id="title_min" translate="label" type="text" sortOrder="20" showInDefault="1">
                    <label>Meta title min length</label>
                </field>
                <field id="title_max" translate="label" type="text" sortOrder="30" showInDefault="1">
                    <label>Meta title max length</label>
                </field>
                <field id="description_min" translate="label" type="text" sortOrder="40" showInDefault="1">
                    <label>Meta description min length</label>
                </field>
                <field id="description_max" translate="label" type="text" sortOrder="50" showInDefault="1">
                    <label>Meta description max length</label>
                </field>
                <field id="thin_description" translate="label" type="text" sortOrder="60" showInDefault="1">
                    <label>Thin product description threshold (chars)</label>
                </field>
            </group>
            <group id="fetch" translate="label" type="text" sortOrder="20" showInDefault="1">
                <label>Page Fetch (rendered-HTML checks)</label>
                <comment>Used by the checks that read live HTML (canonical, indexability). Sampled, on-demand.</comment>
                <field id="sample_size" translate="label" type="text" sortOrder="10" showInDefault="1">
                    <label>Sample size (pages to fetch)</label>
                    <comment>Pages fetched per rendered check (1-200). HTTP-based, so keep it modest.</comment>
                </field>
                <field id="base_url" translate="label" type="text" sortOrder="20" showInDefault="1">
                    <label>Fetch base URL (optional)</label>
                    <comment><![CDATA[Internal origin to fetch from when the public URL is behind Varnish / basic-auth / an edge gate, e.g. <code>http://varnish:80</code>. Leave blank to use the store's secure base URL. The store domain is sent as the Host header.]]></comment>
                </field>
                <field id="basic_auth" translate="label" type="obscure" sortOrder="30" showInDefault="1">
                    <label>Basic auth (optional, user:pass)</label>
                    <backend_model>Magento\Config\Model\Config\Backend\Encrypted</backend_model>
                    <comment>HTTP basic-auth credentials for a gated origin, as user:pass.</comment>
                </field>
            </group>
            <group id="canonical" translate="label" type="text" sortOrder="30" showInDefault="1">
                <label>Canonical Health Check</label>
                <field id="enabled" translate="label" type="select" sortOrder="10" showInDefault="1">
                    <label>Enable canonical check</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <comment>Fetches sample product pages and flags missing / duplicate / redirecting canonicals.</comment>
                </field>
            </group>
            <group id="indexability" translate="label" type="text" sortOrder="40" showInDefault="1">
                <label>Indexability Checks</label>
                <field id="enabled" translate="label" type="select" sortOrder="10" showInDefault="1">
                    <label>Enable indexability checks</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <comment>Flags pages hidden from Google (noindex), live URLs blocked by robots.txt, and dead/redirecting URLs in the XML sitemap.</comment>
                </field>
            </group>
            <group id="social" translate="label" type="text" sortOrder="50" showInDefault="1">
                <label>Social Tags Check</label>
                <field id="enabled" translate="label" type="select" sortOrder="10" showInDefault="1">
                    <label>Enable social tags check</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <comment>Flags product pages missing Open Graph / Twitter Card tags, or an og:url on the wrong domain.</comment>
                </field>
            </group>
            <group id="schema" translate="label" type="text" sortOrder="60" showInDefault="1">
                <label>Structured Data Check</label>
                <field id="enabled" translate="label" type="select" sortOrder="10" showInDefault="1">
                    <label>Enable structured-data check</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <comment>Flags product pages with no Product JSON-LD structured data.</comment>
                </field>
            </group>
            <group id="onpage" translate="label" type="text" sortOrder="70" showInDefault="1">
                <label>On-page Check (H1)</label>
                <field id="enabled" translate="label" type="select" sortOrder="10" showInDefault="1">
                    <label>Enable H1 check</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <comment>Fetches sample product pages and flags a missing or duplicate H1 heading.</comment>
                </field>
            </group>
        </section>
    </system>
</config>
