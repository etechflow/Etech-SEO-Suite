<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:Acl/etc/acl.xsd">
    <acl>
        <resources>
            <resource id="Magento_Backend::admin">
                <resource id="Magento_Backend::marketing">
                    <resource id="Etechflow_RedirectManager::redirect_manager" title="Redirect Manager" sortOrder="80">
                        <resource id="Etechflow_RedirectManager::redirect" title="Redirects" sortOrder="10"/>
                        <resource id="Etechflow_RedirectManager::log" title="404 Log" sortOrder="20"/>
                    </resource>
                </resource>
                <resource id="Magento_Backend::stores">
                    <resource id="Magento_Backend::stores_settings">
                        <resource id="Magento_Config::config">
                            <resource id="Etechflow_RedirectManager::config" title="Redirect Manager Configuration" sortOrder="100"/>
                        </resource>
                    </resource>
                </resource>
            </resource>
        </resources>
    </acl>
</config>
