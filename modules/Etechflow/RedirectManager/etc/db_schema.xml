<?xml version="1.0"?>
<schema xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:Setup/Declaration/Schema/etc/schema.xsd">
    <table name="etechflow_redirect" resource="default" engine="innodb" comment="Etechflow Redirects">
        <column xsi:type="int" name="entity_id" unsigned="true" nullable="false" identity="true" comment="ID"/>
        <column xsi:type="varchar" name="request_path" nullable="false" length="255" comment="From path"/>
        <column xsi:type="varchar" name="target_path" nullable="false" length="500" comment="To path or URL"/>
        <column xsi:type="smallint" name="redirect_type" unsigned="true" nullable="false" default="301" comment="301 or 302"/>
        <column xsi:type="smallint" name="store_id" unsigned="true" nullable="false" default="0" comment="Store (0=all)"/>
        <column xsi:type="smallint" name="is_active" unsigned="true" nullable="false" default="1" comment="Active"/>
        <column xsi:type="int" name="hits" unsigned="true" nullable="false" default="0" comment="Hit count"/>
        <column xsi:type="varchar" name="description" nullable="true" length="255" comment="Note"/>
        <column xsi:type="timestamp" name="created_at" on_update="false" nullable="false" default="CURRENT_TIMESTAMP" comment="Created"/>
        <column xsi:type="timestamp" name="updated_at" on_update="true" nullable="false" default="CURRENT_TIMESTAMP" comment="Updated"/>
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="entity_id"/>
        </constraint>
        <index referenceId="ETECHFLOW_REDIRECT_REQUEST_PATH_STORE_ID" indexType="btree">
            <column name="request_path"/>
            <column name="store_id"/>
        </index>
    </table>
    <table name="etechflow_redirect_404_log" resource="default" engine="innodb" comment="Etechflow 404 Log">
        <column xsi:type="int" name="log_id" unsigned="true" nullable="false" identity="true" comment="ID"/>
        <column xsi:type="varchar" name="request_path" nullable="false" length="255" comment="Requested path"/>
        <column xsi:type="varchar" name="referrer" nullable="true" length="500" comment="Referrer"/>
        <column xsi:type="int" name="hits" unsigned="true" nullable="false" default="1" comment="Hit count"/>
        <column xsi:type="smallint" name="store_id" unsigned="true" nullable="false" default="0" comment="Store"/>
        <column xsi:type="int" name="redirect_id" unsigned="true" nullable="true" comment="Linked redirect"/>
        <column xsi:type="timestamp" name="created_at" on_update="false" nullable="false" default="CURRENT_TIMESTAMP" comment="First seen"/>
        <column xsi:type="timestamp" name="updated_at" on_update="true" nullable="false" default="CURRENT_TIMESTAMP" comment="Last seen"/>
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="log_id"/>
        </constraint>
        <constraint xsi:type="unique" referenceId="ETECHFLOW_REDIRECT_404_LOG_REQUEST_PATH_STORE_ID">
            <column name="request_path"/>
            <column name="store_id"/>
        </constraint>
    </table>
</schema>
