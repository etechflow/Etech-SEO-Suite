<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Store:etc/config.xsd">
    <default>
        <etechflow_sitemap>
            <general>
                <enabled>0</enabled>
                <path>/</path>
                <filename>sitemap.xml</filename>
                <max_urls>50000</max_urls>
            </general>
            <product>
                <enabled>1</enabled>
                <changefreq>daily</changefreq>
                <priority>1.0</priority>
                <add_images>0</add_images>
            </product>
            <category>
                <enabled>1</enabled>
                <changefreq>daily</changefreq>
                <priority>0.5</priority>
            </category>
            <cms>
                <enabled>1</enabled>
                <changefreq>weekly</changefreq>
                <priority>0.25</priority>
            </cms>
            <custom>
                <urls/>
            </custom>
            <exclude>
                <product_skus/>
                <category_ids/>
                <cms_identifiers/>
            </exclude>
            <hreflang>
                <enabled>0</enabled>
            </hreflang>
            <cron>
                <enabled>0</enabled>
            </cron>
        </etechflow_sitemap>
    </default>
</config>
