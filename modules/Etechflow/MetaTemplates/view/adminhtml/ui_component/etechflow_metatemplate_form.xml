<?xml version="1.0"?>
<form xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">
    <argument name="data" xsi:type="array">
        <item name="js_config" xsi:type="array">
            <item name="provider" xsi:type="string">etechflow_metatemplate_form.etechflow_metatemplate_form_data_source</item>
        </item>
        <item name="label" xsi:type="string" translate="true">Template Information</item>
    </argument>
    <settings>
        <buttons>
            <button name="back" class="Etechflow\MetaTemplates\Block\Adminhtml\Template\Edit\BackButton"/>
            <button name="delete" class="Etechflow\MetaTemplates\Block\Adminhtml\Template\Edit\DeleteButton"/>
            <button name="save" class="Etechflow\MetaTemplates\Block\Adminhtml\Template\Edit\SaveButton"/>
        </buttons>
        <namespace>etechflow_metatemplate_form</namespace>
        <dataScope>data</dataScope>
        <deps>
            <dep>etechflow_metatemplate_form.etechflow_metatemplate_form_data_source</dep>
        </deps>
    </settings>
    <dataSource name="etechflow_metatemplate_form_data_source">
        <argument name="data" xsi:type="array">
            <item name="js_config" xsi:type="array">
                <item name="component" xsi:type="string">Magento_Ui/js/form/provider</item>
            </item>
        </argument>
        <settings>
            <submitUrl path="metatemplates/template/save"/>
        </settings>
        <dataProvider class="Etechflow\MetaTemplates\Model\TemplateForm\DataProvider" name="etechflow_metatemplate_form_data_source">
            <settings>
                <requestFieldName>template_id</requestFieldName>
                <primaryFieldName>template_id</primaryFieldName>
            </settings>
        </dataProvider>
    </dataSource>
    <fieldset name="general">
        <settings>
            <label translate="true">General</label>
        </settings>
        <field name="template_id" formElement="hidden">
            <settings>
                <dataType>number</dataType>
            </settings>
        </field>
        <field name="name" formElement="input" sortOrder="10">
            <settings>
                <dataType>text</dataType>
                <label translate="true">Rule Name</label>
                <validation><rule name="required-entry" xsi:type="boolean">true</rule></validation>
            </settings>
        </field>
        <field name="applies_to" formElement="select" sortOrder="20">
            <settings>
                <dataType>text</dataType>
                <label translate="true">Applies To</label>
                <validation><rule name="required-entry" xsi:type="boolean">true</rule></validation>
            </settings>
            <formElements>
                <select>
                    <settings>
                        <options class="Etechflow\MetaTemplates\Model\Config\Source\AppliesTo"/>
                    </settings>
                </select>
            </formElements>
        </field>
        <field name="store_id" formElement="select" sortOrder="30">
            <settings>
                <dataType>number</dataType>
                <label translate="true">Store View</label>
            </settings>
            <formElements>
                <select>
                    <settings>
                        <options class="Etechflow\MetaTemplates\Model\Config\Source\Stores"/>
                    </settings>
                </select>
            </formElements>
        </field>
        <field name="category_id" formElement="input" sortOrder="40">
            <settings>
                <dataType>number</dataType>
                <label translate="true">Limit to Category ID</label>
                <notice translate="true">Optional. For product rules only — applies the template only to products in this category. Leave blank for all.</notice>
            </settings>
        </field>
        <field name="priority" formElement="input" sortOrder="50">
            <settings>
                <dataType>number</dataType>
                <label translate="true">Priority</label>
                <notice translate="true">Higher priority wins when multiple rules match.</notice>
                <default>0</default>
            </settings>
        </field>
        <field name="is_active" formElement="select" sortOrder="60">
            <settings>
                <dataType>number</dataType>
                <label translate="true">Status</label>
            </settings>
            <formElements>
                <select>
                    <settings>
                        <options class="Magento\Config\Model\Config\Source\Enabledisable"/>
                    </settings>
                </select>
            </formElements>
        </field>
    </fieldset>
    <fieldset name="meta">
        <settings>
            <label translate="true">Meta Templates</label>
        </settings>
        <field name="meta_title" formElement="input" sortOrder="10">
            <settings>
                <dataType>text</dataType>
                <label translate="true">Meta Title</label>
                <notice translate="true">e.g. {{product.name}} | Buy Online at {{store.name}}</notice>
            </settings>
        </field>
        <field name="meta_description" formElement="textarea" sortOrder="20">
            <settings>
                <dataType>text</dataType>
                <label translate="true">Meta Description</label>
                <notice translate="true">e.g. Shop {{product.name}} from only {{product.price}}. Fast UK delivery from {{store.name}}.</notice>
            </settings>
        </field>
        <field name="meta_keywords" formElement="textarea" sortOrder="30">
            <settings>
                <dataType>text</dataType>
                <label translate="true">Meta Keywords</label>
            </settings>
        </field>
    </fieldset>
</form>
