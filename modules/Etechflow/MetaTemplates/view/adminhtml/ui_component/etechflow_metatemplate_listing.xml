<?xml version="1.0"?>
<listing xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">
    <argument name="data" xsi:type="array">
        <item name="js_config" xsi:type="array">
            <item name="provider" xsi:type="string">etechflow_metatemplate_listing.etechflow_metatemplate_listing_data_source</item>
        </item>
    </argument>
    <settings>
        <spinner>etechflow_metatemplate_columns</spinner>
        <deps>
            <dep>etechflow_metatemplate_listing.etechflow_metatemplate_listing_data_source</dep>
        </deps>
        <buttons>
            <button name="add">
                <url path="*/*/new"/>
                <class>primary</class>
                <label translate="true">Add New Template</label>
            </button>
        </buttons>
    </settings>
    <dataSource name="etechflow_metatemplate_listing_data_source" component="Magento_Ui/js/grid/provider">
        <settings>
            <storageConfig>
                <param name="indexField" xsi:type="string">template_id</param>
            </storageConfig>
            <updateUrl path="mui/index/render"/>
        </settings>
        <aclResource>Etechflow_MetaTemplates::template</aclResource>
        <dataProvider class="Magento\Framework\View\Element\UiComponent\DataProvider\DataProvider" name="etechflow_metatemplate_listing_data_source">
            <settings>
                <requestFieldName>template_id</requestFieldName>
                <primaryFieldName>template_id</primaryFieldName>
            </settings>
        </dataProvider>
    </dataSource>
    <listingToolbar name="listing_top">
        <bookmark name="bookmarks"/>
        <columnsControls name="columns_controls"/>
        <filters name="listing_filters"/>
        <massaction name="listing_massaction">
            <action name="delete">
                <settings>
                    <confirm>
                        <message translate="true">Delete selected templates?</message>
                        <title translate="true">Delete templates</title>
                    </confirm>
                    <url path="metatemplates/template/massDelete"/>
                    <type>delete</type>
                    <label translate="true">Delete</label>
                </settings>
            </action>
        </massaction>
        <paging name="listing_paging"/>
    </listingToolbar>
    <columns name="etechflow_metatemplate_columns">
        <selectionsColumn name="ids">
            <settings>
                <indexField>template_id</indexField>
            </settings>
        </selectionsColumn>
        <column name="template_id">
            <settings>
                <filter>textRange</filter>
                <label translate="true">ID</label>
                <sorting>desc</sorting>
            </settings>
        </column>
        <column name="name">
            <settings>
                <filter>text</filter>
                <label translate="true">Name</label>
            </settings>
        </column>
        <column name="applies_to" component="Magento_Ui/js/grid/columns/select">
            <settings>
                <options class="Etechflow\MetaTemplates\Model\Config\Source\AppliesTo"/>
                <filter>select</filter>
                <dataType>select</dataType>
                <label translate="true">Applies To</label>
            </settings>
        </column>
        <column name="store_id" component="Magento_Ui/js/grid/columns/select">
            <settings>
                <options class="Etechflow\MetaTemplates\Model\Config\Source\Stores"/>
                <filter>select</filter>
                <dataType>select</dataType>
                <label translate="true">Store View</label>
            </settings>
        </column>
        <column name="priority">
            <settings>
                <filter>textRange</filter>
                <label translate="true">Priority</label>
            </settings>
        </column>
        <column name="is_active" component="Magento_Ui/js/grid/columns/select">
            <settings>
                <options class="Magento\Config\Model\Config\Source\Enabledisable"/>
                <filter>select</filter>
                <dataType>select</dataType>
                <label translate="true">Status</label>
            </settings>
        </column>
        <actionsColumn name="actions" class="Etechflow\MetaTemplates\Ui\Component\Listing\Column\TemplateActions">
            <settings>
                <indexField>template_id</indexField>
            </settings>
        </actionsColumn>
    </columns>
</listing>
